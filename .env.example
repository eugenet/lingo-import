# LingQ API key from https://www.lingq.com/en/accounts/apikey/
LINGQ_API_KEY=Token your_api_key_here

# Course ID (pk from collections) - required for upload
LINGQ_COURSE_ID=50220

# Language code, e.g. en, es, fr, de
LINGQ_LANGUAGE=es

# Level 0-6: 0=No Knowledge, 1-2=Beginner, 3-4=Intermediate, 5-6=Advanced
LINGQ_LEVEL=3
